# FinMate Backend — Environment Variables (copy to .env and fill in)

# ─── Auth (REQUIRED in production) ───
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_DAYS=30
DEMO_PASSWORD=demo1234

# ─── Database ───
# Default: SQLite (works with zero setup). Production: use managed Postgres.
DATABASE_URL=sqlite:///./finmate.db
# DATABASE_URL=postgresql://user:pass@host:5432/finmate

# ─── AI / LLM ───
# Primary: Groq (fast, generous free tier) — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Fallbacks
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=groq

# ─── Vector DB (Qdrant) — optional, keyword fallback if unset ───
QDRANT_API_KEY=
QDRANT_URL=

# ─── Graph DB (Neo4j) — optional, relational fallback if unset ───
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# ─── Admin (view signup/waitlist counts at /api/admin/stats?key=...) ───
ADMIN_KEY=set-a-secret-admin-key

# ─── Email (magic login links) — optional ───
# Free tier: 3,000/mo at https://resend.com. If unset, magic links are shown
# on screen (dev mode) instead of emailed.
RESEND_API_KEY=
FROM_EMAIL=FinMate <onboarding@resend.dev>

# ─── CORS ───
FRONTEND_ORIGIN=http://localhost:3000
# Comma-separated extra allowed origins for production (e.g. your Vercel URL)
EXTRA_ORIGINS=
