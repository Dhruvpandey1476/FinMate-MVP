# FinMate Backend Environment Variables

# Database (defaults to local SQLite — no setup needed for the demo)
DATABASE_URL=sqlite:///./finmate.db

# Optional: plug in a real LLM for the AI CFO's reasoning/explanations.
# If left blank, FinMate runs fully on its built-in rule-based reasoning engine
# (deterministic, demo-safe, zero API cost — great for hackathon judging).
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=mock
# Options for LLM_PROVIDER: mock | gemini | openai

# CORS
FRONTEND_ORIGIN=http://localhost:3000
