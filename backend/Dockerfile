FROM python:3.12-slim

WORKDIR /app

# System deps for pdfplumber / pandas wheels are already prebuilt; keep image lean.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app ./app

ENV PYTHONUNBUFFERED=1
EXPOSE 8000

# $PORT is provided by most PaaS (Render/Railway); default 8000 locally.
CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
